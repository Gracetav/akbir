<%- include('../layouts/header') %>

<div class="min-h-screen flex items-center justify-center p-6 bg-gradient-to-br from-slate-50 to-indigo-100">
    <div class="w-full max-w-lg bg-white rounded-[2.5rem] shadow-2xl p-12 border border-slate-100 relative group overflow-hidden">
        <!-- Floating shapes Backdrop -->
        <div class="absolute -right-16 -top-16 w-32 h-32 bg-indigo-200 rounded-full blur-3xl opacity-30 group-hover:opacity-50 transition-soft"></div>
        <div class="absolute -left-16 -bottom-16 w-32 h-32 bg-sky-200 rounded-full blur-3xl opacity-30 group-hover:opacity-50 transition-soft"></div>
        
        <div class="relative z-10">
            <div class="flex justify-center mb-8">
                <div class="bg-indigo-600 p-3 rounded-2xl shadow-xl transform group-hover:scale-110 transition-soft">
                    <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path>
                    </svg>
                </div>
            </div>
            
            <h2 class="text-3xl font-extrabold text-slate-800 text-center mb-2 tracking-tight">Akbir <span class="text-indigo-600">Parts</span></h2>
            <p class="text-slate-500 text-center mb-10 text-lg">Solusi sparepart kendaraan Anda dalam satu aplikasi</p>
            
            <% if (error) { %>
                <div class="bg-red-50 border border-red-100 p-4 mb-8 rounded-2xl animate-shake">
                    <p class="text-red-700 text-sm font-bold flex items-center">
                        <svg class="h-5 w-5 mr-2" fill="currentColor" viewBox="0 0 20 20"><path d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" fill-rule="evenodd" clip-rule="evenodd"></path></svg>
                        <%= error %>
                    </p>
                </div>
            <% } %>

            <form action="/auth/login" method="POST" class="space-y-6">
                <div class="space-y-2">
                    <label for="email" class="block text-sm font-bold text-slate-700">Email Utama</label>
                    <input type="email" id="email" name="email" required 
                        class="block w-full px-5 py-4 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-indigo-100 focus:border-indigo-500 transition-soft text-slate-800 bg-slate-50 border-none outline-none ring-0 shadow-sm"
                        placeholder="email@gmail.com">
                </div>
                
                <div class="space-y-2">
                    <div class="flex justify-between items-center">
                        <label for="password" class="block text-sm font-bold text-slate-700">Kata Sandi</label>
                        <a href="#" class="text-xs font-bold text-indigo-600 hover:text-indigo-800">Lupa Password?</a>
                    </div>
                    <input type="password" id="password" name="password" required 
                        class="block w-full px-5 py-4 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-indigo-100 focus:border-indigo-500 transition-soft text-slate-800 bg-slate-50 border-none outline-none ring-0 shadow-sm"
                        placeholder="••••••••">
                </div>

                <button type="submit" 
                    class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-black py-4 px-6 rounded-2xl shadow-xl shadow-indigo-200 transform active:scale-95 transition-soft mt-4">
                    Masuk Sekarang
                </button>
            </form>
            
            <div class="mt-12 text-center text-sm">
                <p class="text-slate-400 font-medium">Belum punya akun? <a href="#" class="text-indigo-600 font-bold hover:underline">Daftar sekarang</a></p>
            </div>
        </div>
    </div>
</div>

<%- include('../layouts/footer') %>
