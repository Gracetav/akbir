<%- include('../layouts/header') %>

<div class="min-h-screen flex items-center justify-center p-6 bg-gradient-to-br from-slate-50 to-indigo-100">
    <div class="w-full max-w-lg bg-white rounded-[2.5rem] shadow-2xl p-12 border border-slate-100 relative group overflow-hidden">
        <!-- Decoration -->
        <div class="absolute -right-16 -top-16 w-32 h-32 bg-emerald-200 rounded-full blur-3xl opacity-30 group-hover:opacity-50 transition-soft"></div>
        
        <div class="relative z-10">
            <h2 class="text-3xl font-extrabold text-slate-800 text-center mb-2 tracking-tight">Daftar Akun Baru</h2>
            <p class="text-slate-500 text-center mb-10 text-lg">Bergabunglah dengan Akbir Parts hari ini</p>
            
            <% if (error) { %>
                <div class="bg-red-50 border border-red-100 p-4 mb-8 rounded-2xl">
                    <p class="text-red-700 text-sm font-bold"><%= error %></p>
                </div>
            <% } %>

            <form action="/auth/register" method="POST" class="space-y-6">
                <div class="space-y-2">
                    <label for="name" class="block text-sm font-bold text-slate-700">Nama Lengkap</label>
                    <input type="text" id="name" name="name" required 
                        class="block w-full px-5 py-4 bg-slate-50 border-none rounded-2xl focus:ring-4 focus:ring-indigo-100 transition-soft text-slate-800 outline-none shadow-sm"
                        placeholder="Nama Anda">
                </div>

                <div class="space-y-2">
                    <label for="email" class="block text-sm font-bold text-slate-700">Alamat Email</label>
                    <input type="email" id="email" name="email" required 
                        class="block w-full px-5 py-4 bg-slate-50 border-none rounded-2xl focus:ring-4 focus:ring-indigo-100 transition-soft text-slate-800 outline-none shadow-sm"
                        placeholder="email@gmail.com">
                </div>
                
                <div class="space-y-2">
                    <label for="password" class="block text-sm font-bold text-slate-700">Kata Sandi</label>
                    <input type="password" id="password" name="password" required 
                        class="block w-full px-5 py-4 bg-slate-50 border-none rounded-2xl focus:ring-4 focus:ring-indigo-100 transition-soft text-slate-800 outline-none shadow-sm"
                        placeholder="••••••••">
                </div>

                <button type="submit" 
                    class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-black py-4 px-6 rounded-2xl shadow-xl shadow-emerald-100 transform active:scale-95 transition-soft mt-4">
                    Buat Akun Sekarang &rarr;
                </button>
            </form>
            
            <div class="mt-10 text-center text-sm">
                <p class="text-slate-400 font-medium">Sudah punya akun? <a href="/auth/login" class="text-indigo-600 font-bold hover:underline">Masuk di sini</a></p>
            </div>
        </div>
    </div>
</div>

<%- include('../layouts/footer') %>
