<%- include('../layouts/header') %>
<%- include('../layouts/navbar') %>

<main class="max-w-7xl mx-auto px-6 py-12">
    <!-- Hero Box -->
    <div class="mb-16 rounded-[2.5rem] bg-indigo-600 p-10 md:p-20 text-white relative overflow-hidden shadow-2xl flex flex-col md:flex-row items-center gap-10">
        <div class="relative z-10 max-w-2xl text-center md:text-left">
            <span class="inline-block px-4 py-1 bg-white/20 text-[10px] font-black uppercase tracking-widest rounded-lg mb-6 ring-1 ring-white/30 backdrop-blur-sm">Premium Catalog</span>
            <h1 class="text-4xl md:text-6xl font-black tracking-tighter leading-tight mb-6 text-white">Sparepart Orisinal<br><span class="text-indigo-200 drop-shadow-xl underline decoration-indigo-400/50">Kualitas Terbaik.</span></h1>
            <p class="text-indigo-100 font-medium mb-8 opacity-90 leading-relaxed italic text-sm md:text-base">"Rawat kendaraan Anda dengan suku cadang terpercaya dari Akbir Parts."</p>
            <div class="flex flex-wrap gap-4 justify-center md:justify-start">
                <a href="#katalog" class="bg-white text-indigo-700 font-black px-8 py-4 rounded-2xl shadow-xl hover:bg-slate-50 transition-soft active:scale-95">Mulai Belanja</a>
                <a href="/customer/history" class="bg-indigo-500/30 text-white font-bold px-8 py-4 rounded-2xl backdrop-blur-md border border-white/20 transition-soft">Riwayat</a>
            </div>
        </div>
        <div class="absolute -right-20 -bottom-20 w-80 h-80 bg-white opacity-10 rounded-full blur-[100px]"></div>
    </div>

    <!-- Grid Katalog -->
    <div id="katalog" class="space-y-10">
        <div class="flex items-center justify-between border-b border-slate-100 pb-8">
            <h2 class="text-3xl font-black text-slate-800 tracking-tight">Katalog <span class="text-indigo-600">Terbaru</span></h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
            <% parts.forEach(part => { %>
                <div class="bg-white rounded-[2rem] shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-soft flex flex-col h-full border border-slate-100 overflow-hidden group">
                    
                    <!-- Image Area -->
                    <div class="relative h-56 bg-slate-50 overflow-hidden">
                        <% if(part.image) { %>
                            <img src="<%= part.image %>" 
                                 onerror="this.src='https://images.unsplash.com/photo-1486006396113-ad7302ff172a?auto=format&fit=crop&q=80&w=400'; this.onerror=null;"
                                 alt="<%= part.name %>" 
                                 class="w-full h-full object-cover group-hover:scale-110 transition-soft">
                        <% } else { %>
                            <div class="w-full h-full flex flex-col items-center justify-center text-slate-300">
                                <svg class="w-12 h-12 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                                <span class="text-[10px] font-bold uppercase tracking-widest text-slate-400">No Image</span>
                            </div>
                        <% } %>
                        <div class="absolute top-4 left-4">
                            <span class="bg-white/90 backdrop-blur-md text-indigo-600 text-[10px] font-black uppercase px-3 py-1.5 rounded-lg shadow-sm border border-white/50 ring-1 ring-indigo-50">Terlaris</span>
                        </div>
                    </div>
                    
                    <!-- Content Area -->
                    <div class="p-8 flex flex-col flex-grow">
                        <h3 class="text-lg font-black text-slate-800 leading-tight line-clamp-1 mb-2 group-hover:text-indigo-600 transition-soft"><%= part.name %></h3>
                        <p class="text-slate-400 text-xs line-clamp-2 h-8 font-medium leading-relaxed"><%= part.description %></p>
                        
                        <div class="mt-8 pt-6 border-t border-slate-50">
                            <div class="flex items-end justify-between mb-6">
                                <div class="space-y-1">
                                    <p class="text-[9px] font-bold text-slate-300 uppercase tracking-widest">Harga Jual</p>
                                    <p class="text-xl font-black text-slate-900 tracking-tighter">Rp <%= part.price.toLocaleString('id-ID') %></p>
                                </div>
                                <div class="text-right space-y-1">
                                    <p class="text-[9px] font-bold text-slate-300 uppercase tracking-widest">Ready Stok</p>
                                    <p class="<%= part.stock > 0 ? 'text-emerald-500' : 'text-red-500' %> text-xs font-black uppercase tracking-widest"><%= part.stock %> Unit</p>
                                </div>
                            </div>

                            <form action="/customer/cart" method="POST" class="flex gap-3">
                                <input type="hidden" name="id" value="<%= part.id %>">
                                <input type="number" name="qty" value="1" min="1" max="<%= part.stock %>" required
                                    class="w-16 px-2 py-3 bg-slate-50 border-none rounded-xl focus:ring-4 focus:ring-indigo-100 text-center font-black text-slate-800 outline-none shadow-sm capitalize ring-0">
                                <button type="submit" <%= part.stock <= 0 ? 'disabled' : '' %>
                                    class="flex-grow bg-indigo-600 hover:bg-slate-800 disabled:bg-slate-200 text-white font-black py-4 px-4 rounded-xl shadow-lg shadow-indigo-100 transition-soft active:scale-95 text-[10px] uppercase tracking-widest flex items-center justify-center gap-2">
                                    <% if(part.stock > 0) { %>
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 4v16m8-8H4" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                                        Tambah Keranjang
                                    <% } else { %>
                                        Stok Habis
                                    <% } %>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</main>

<%- include('../layouts/footer') %>
