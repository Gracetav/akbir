<%- include('../layouts/header') %>
<%- include('../layouts/navbar') %>

<main class="max-w-7xl mx-auto px-6 py-12">
    <div class="mb-12 flex flex-col md:flex-row justify-between items-end gap-6 border-b border-slate-100 pb-10">
        <div>
            <h1 class="text-5xl font-black text-slate-800 tracking-tight leading-tight">Konfirmasi <span class="text-indigo-600">Pembayaran</span></h1>
            <p class="mt-4 text-xl text-slate-500 font-medium italic">Silakan transfer dan upload bukti pembayaran untuk diproses Admin.</p>
        </div>
        <a href="/customer" class="flex items-center text-indigo-600 hover:text-indigo-800 font-bold mb-4 transition-soft group">
            <svg class="w-5 h-5 mr-3 group-hover:-translate-x-2 transition-soft" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg> 
            Belanja Lagi
        </a>
    </div>

    <!-- Company Bank Info -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
        <div class="bg-gradient-to-br from-slate-800 to-slate-900 rounded-[2.5rem] p-10 text-white shadow-2xl relative overflow-hidden group">
            <div class="relative z-10">
                <div class="flex items-center gap-4 mb-8">
                    <div class="p-3 bg-white/10 rounded-2xl backdrop-blur-md">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                    </div>
                    <span class="text-sm font-bold uppercase tracking-widest opacity-60">Metode Transfer</span>
                </div>
                <div class="space-y-6">
                    <div class="pb-6 border-b border-white/10">
                        <p class="text-xs font-bold text-indigo-400 uppercase tracking-widest mb-1">Bank Central Asia (BCA)</p>
                        <p class="text-2xl font-black tracking-tighter">7710 4421 99</p>
                        <p class="text-sm font-medium opacity-60">A.N. PT AKBIR PARTS INDONESIA</p>
                    </div>
                </div>
            </div>
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-indigo-500/20 rounded-full blur-[80px]"></div>
        </div>

        <div class="bg-indigo-600 rounded-[2.5rem] p-10 text-white shadow-2xl relative overflow-hidden group">
            <div class="relative z-10 flex flex-col justify-center h-full">
                <h3 class="text-2xl font-black mb-4">Butuh Bantuan?</h3>
                <p class="text-indigo-100 font-medium mb-8 leading-relaxed italic">"Simpan struk transfer Anda. Admin kami akan melakukan verifikasi maksimal 1x24 jam."</p>
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-2xl bg-white/20 flex items-center justify-center backdrop-blur-md">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                    </div>
                    <span class="font-bold underline cursor-pointer">Hubungi Telegram CS</span>
                </div>
            </div>
            <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-white/10 rounded-full blur-[80px]"></div>
        </div>
    </div>

    <!-- Transaction List -->
    <div class="flex flex-col gap-12">
        <% history.forEach(trx => { %>
            <div class="bg-white rounded-[3rem] shadow-sm border border-slate-100 group overflow-hidden flex flex-col ring-1 ring-slate-100 transition-soft hover:shadow-xl">
                <div class="flex flex-col md:flex-row divide-y md:divide-y-0 md:divide-x divide-slate-50">
                    
                    <div class="md:w-72 p-10 flex flex-col justify-between relative overflow-hidden bg-gradient-to-br <%= trx.status === 'pending' ? 'from-amber-400 to-amber-600' : (trx.status === 'confirmed' ? 'from-indigo-500 to-indigo-700' : 'from-emerald-500 to-emerald-700') %> text-white">
                        <div>
                            <div class="text-[10px] font-black uppercase tracking-widest opacity-80 mb-2">Status</div>
                            <div class="text-3xl font-black uppercase tracking-tighter"><%= trx.status %></div>
                        </div>
                        <div class="mt-8">
                            <div class="text-[10px] font-black opacity-80 mb-2 uppercase tracking-widest">No. Invoice</div>
                            <div class="text-xl font-mono font-black tracking-tighter">#TRX-<%= trx.id.toString().padStart(4, '0') %></div>
                        </div>
                    </div>
                    
                    <div class="flex-grow p-10 flex flex-col md:flex-row justify-between items-center bg-white relative">
                        <div class="text-center md:text-left mb-6 md:mb-0 space-y-2">
                            <div class="text-[10px] font-black text-slate-300 uppercase tracking-widest">Total Bayar</div>
                            <div class="text-3xl font-black text-slate-800 tracking-tighter tabular-nums drop-shadow-sm">
                                Rp <%= trx.total_price.toLocaleString('id-ID') %>
                            </div>
                            <div class="text-[10px] font-bold text-slate-400 mt-2"><%= new Date(trx.created_at).toLocaleString('id-ID') %></div>
                        </div>

                        <div class="flex flex-col items-center md:items-end gap-6">
                            <% if (trx.status === 'pending') { %>
                                <% if (trx.payment_proof) { %>
                                    <div class="flex flex-col items-center md:items-end">
                                        <span class="inline-flex items-center px-4 py-2 bg-indigo-50 text-indigo-600 rounded-2xl text-[10px] font-black uppercase tracking-widest border border-indigo-100 ring-4 ring-indigo-50/50 mb-3">Sudah Upload</span>
                                        <p class="text-[10px] font-bold text-slate-400 italic">Menunggu Verifikasi Admin</p>
                                    </div>
                                <% } else { %>
                                    <form action="/customer/upload-proof" method="POST" enctype="multipart/form-data" class="flex flex-col md:flex-row items-center gap-3">
                                        <input type="hidden" name="id" value="<%= trx.id %>">
                                        <div class="relative group">
                                            <input type="file" name="proof" required class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10">
                                            <div class="px-6 py-3 bg-slate-50 border-2 border-dashed border-slate-200 rounded-2xl text-[10px] font-black text-slate-500 group-hover:bg-indigo-50 group-hover:border-indigo-200 transition-soft">
                                                Pilih Bukti Transfer
                                            </div>
                                        </div>
                                        <button type="submit" class="bg-indigo-600 hover:bg-slate-800 text-white px-8 py-3 rounded-2xl text-xs font-black shadow-lg shadow-indigo-100 transition-soft active:scale-95">Upload & Bayar</button>
                                    </form>
                                <% } %>
                            <% } else { %>
                                <div class="px-6 py-3 bg-emerald-50 rounded-2xl text-emerald-600 text-[10px] font-black border border-emerald-100 uppercase tracking-widest">Pembayaran Terverifikasi</div>
                            <% } %>
                        </div>
                    </div>
                </div>
                
                <% if(trx.payment_proof) { %>
                <div class="px-10 py-4 bg-slate-50 flex items-center justify-between border-t border-slate-100">
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest italic font-medium">Buka Gambar Bukti Transfer &rarr;</p>
                    <a href="<%= trx.payment_proof %>" target="_blank" class="h-10 w-10 rounded-xl overflow-hidden border border-slate-200 hover:scale-110 transition-soft">
                        <img src="<%= trx.payment_proof %>" class="w-full h-full object-cover">
                    </a>
                </div>
                <% } %>
            </div>
        <% }) %>
        
        <% if (history.length === 0) { %>
            <div class="bg-slate-50 rounded-[3rem] p-32 text-center flex flex-col items-center justify-center border-4 border-dashed border-slate-100 italic">
                <h3 class="text-3xl font-black text-slate-800 tracking-tight">Belum ada transaksi</h3>
                <p class="text-slate-400 mt-4 text-lg">Silakan belanja sparepart terlebih dahulu.</p>
            </div>
        <% } %>
    </div>
</main>

<%- include('../layouts/footer') %>
