<%- include('../layouts/header') %>
<%- include('../layouts/navbar') %>

<div class="flex">
    <%- include('../layouts/sidebar', { active: 'transactions' }) %>
    
    <main class="flex-grow lg:pl-72 p-12 max-w-screen-2xl mx-auto">
        <div class="mb-12">
            <h1 class="text-4xl font-black text-slate-800 tracking-tight leading-tight">Konfirmasi <span class="text-indigo-600">Transaksi</span></h1>
            <p class="mt-2 text-lg text-slate-500">Verifikasi bukti transfer dari customer sebelum mengirim barang.</p>
        </div>

        <div class="bg-white rounded-[2.5rem] shadow-sm border border-slate-100 overflow-hidden ring-1 ring-slate-100">
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-slate-50">
                        <tr>
                            <th class="px-10 py-6 text-xs font-bold text-slate-500 uppercase tracking-widest">ID</th>
                            <th class="px-10 py-6 text-xs font-bold text-slate-500 uppercase tracking-widest">Customer</th>
                            <th class="px-10 py-6 text-xs font-bold text-slate-500 uppercase tracking-widest text-center">Bukti Transfer</th>
                            <th class="px-10 py-6 text-xs font-bold text-slate-500 uppercase tracking-widest text-center">Total Tagihan</th>
                            <th class="px-10 py-6 text-xs font-bold text-slate-500 uppercase tracking-widest text-center">Status</th>
                            <th class="px-10 py-6 text-xs font-bold text-slate-500 uppercase tracking-widest text-right">Aksi</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-50">
                        <% transactions.forEach(trx => { %>
                        <tr class="hover:bg-indigo-50/20 transition-soft group">
                            <td class="px-10 py-8">
                                <span class="text-sm font-black text-slate-800 tracking-tighter">#TRX-<%= trx.id.toString().padStart(4, '0') %></span>
                            </td>
                            <td class="px-10 py-8">
                                <div class="text-md font-bold text-slate-800"><%= trx.customer_name %></div>
                                <div class="text-[10px] font-bold text-slate-400 mt-1 uppercase tracking-widest"><%= new Date(trx.created_at).toLocaleString('id-ID') %></div>
                            </td>
                            <td class="px-10 py-8 text-center">
                                <% if (trx.payment_proof) { %>
                                    <a href="<%= trx.payment_proof %>" target="_blank" class="inline-flex items-center gap-2 group/proof">
                                        <div class="h-12 w-12 rounded-xl overflow-hidden border-2 border-primary group-hover/proof:scale-110 transition-soft transition-all ring-4 ring-indigo-50">
                                            <img src="<%= trx.payment_proof %>" class="w-full h-full object-cover">
                                        </div>
                                        <span class="text-[9px] font-black text-indigo-600 uppercase tracking-widest block bg-indigo-50 px-2 py-1 rounded-md transition-soft">Lihat Bukti</span>
                                    </a>
                                <% } else { %>
                                    <span class="text-slate-300 italic text-[10px] uppercase font-black tracking-widest">Belum Upload</span>
                                <% } %>
                            </td>
                            <td class="px-10 py-8 text-center">
                                <span class="text-lg font-black text-indigo-700 tracking-tighter tabular-nums">Rp <%= trx.total_price.toLocaleString('id-ID') %></span>
                            </td>
                            <td class="px-10 py-8 text-center">
                                <% if (trx.status === 'pending') { %>
                                    <span class="px-4 py-2 bg-amber-100 text-amber-700 rounded-lg text-[10px] font-black uppercase tracking-widest ring-4 ring-amber-50">Pending</span>
                                <% } else if (trx.status === 'confirmed') { %>
                                    <span class="px-4 py-2 bg-blue-100 text-blue-700 rounded-lg text-[10px] font-black uppercase tracking-widest ring-4 ring-blue-50">Confirmed</span>
                                <% } else { %>
                                    <span class="px-4 py-2 bg-emerald-100 text-emerald-700 rounded-lg text-[10px] font-black uppercase tracking-widest ring-4 ring-emerald-50">Shipped</span>
                                <% } %>
                            </td>
                            <td class="px-10 py-8 text-right">
                                <div class="flex justify-end gap-2">
                                    <% if (trx.status === 'pending') { %>
                                        <a href="/admin/transactions/update/<%= trx.id %>/confirmed" class="bg-indigo-600 hover:bg-slate-800 text-white px-6 py-3 rounded-xl text-xs font-black shadow-lg shadow-indigo-100 transition-soft active:scale-95 <%= !trx.payment_proof ? 'opacity-50 pointer-events-none' : '' %>">
                                            Konfirmasi Transfer
                                        </a>
                                    <% } else if (trx.status === 'confirmed') { %>
                                        <a href="/admin/transactions/update/<%= trx.id %>/shipped" class="bg-emerald-600 hover:bg-emerald-700 text-white px-6 py-3 rounded-xl text-xs font-black shadow-lg shadow-emerald-100 transition-soft active:scale-95">Kirim Barang</a>
                                    <% } else { %>
                                        <div class="px-6 py-3 border border-slate-100 text-slate-400 text-xs font-bold rounded-xl bg-slate-50 cursor-default uppercase">Selesai</div>
                                    <% } %>
                                </div>
                                <% if (trx.status === 'pending' && !trx.payment_proof) { %>
                                    <p class="text-[9px] font-bold text-red-400 mt-2 tracking-widest uppercase">Tunggu Bukti Transfer</p>
                                <% } %>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>

<%- include('../layouts/footer') %>
