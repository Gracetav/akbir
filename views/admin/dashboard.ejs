<%- include('../layouts/header') %>
<%- include('../layouts/navbar') %>

<div class="flex">
    <%- include('../layouts/sidebar') %>
    
    <main class="flex-grow lg:pl-64 pt-8 p-8 max-w-screen-2xl mx-auto">
        <!-- Header Statistics -->
        <div class="mb-10">
            <h1 class="text-3xl font-black text-slate-800 tracking-tight mb-2">Statistik Inventori</h1>
            <p class="text-slate-500">Kelola persediaan suku cadang Anda dengan mudah dan efisien.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
            <div class="bg-white p-8 rounded-[2rem] shadow-sm border border-slate-100 relative overflow-hidden group transition-soft hover:shadow-xl">
                <div class="relative z-10">
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Total Produk</p>
                    <p class="text-4xl font-extrabold text-slate-800"><%= stats.totalParts %></p>
                    <div class="mt-4 flex items-center text-xs font-bold text-emerald-500">
                        <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20"><path d="M5.23 7.21L9 10.98l3.77-3.77 1.41 1.41L9 13.81 3.82 8.62l1.41-1.41z"/></svg> 2% naik bulan ini
                    </div>
                </div>
                <div class="absolute -right-4 -top-4 w-20 h-20 bg-indigo-50 rounded-full blur-2xl group-hover:bg-indigo-100 transition-soft"></div>
            </div>
            
            <div class="bg-white p-8 rounded-[2rem] shadow-sm border border-slate-100 relative overflow-hidden group transition-soft hover:shadow-xl">
                <div class="relative z-10">
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Stok Tersedia</p>
                    <p class="text-4xl font-extrabold text-slate-800"><%= stats.totalStock %></p>
                    <p class="mt-4 text-xs font-bold text-indigo-500 uppercase tracking-widest">Unit Aktif</p>
                </div>
                <div class="absolute -right-4 -top-4 w-20 h-20 bg-blue-50 rounded-full blur-2xl group-hover:bg-blue-100 transition-soft"></div>
            </div>

            <div class="bg-white p-8 rounded-[2rem] shadow-sm border border-slate-100 relative overflow-hidden group transition-soft hover:shadow-xl">
                <div class="relative z-10">
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Total Transaksi</p>
                    <p class="text-4xl font-extrabold text-slate-800"><%= stats.totalTransactions %></p>
                    <div class="mt-4 flex items-center text-xs font-bold text-emerald-500">
                        <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20"><path d="M5.23 7.21L9 10.98l3.77-3.77 1.41 1.41L9 13.81 3.82 8.62l1.41-1.41z"/></svg> Sesuai Target
                    </div>
                </div>
                <div class="absolute -right-4 -top-4 w-20 h-20 bg-emerald-50 rounded-full blur-2xl group-hover:bg-emerald-100 transition-soft"></div>
            </div>

            <div class="bg-white p-8 rounded-[2rem] shadow-sm border border-slate-100 relative overflow-hidden group transition-soft hover:shadow-xl">
                <div class="relative z-10">
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Pesanan Tertunda</p>
                    <p class="text-4xl font-extrabold text-orange-500"><%= stats.pendingTransactions %></p>
                    <a href="/admin/transactions" class="mt-4 block text-xs font-bold text-orange-600 underline uppercase tracking-widest">Segera Proses</a>
                </div>
                <div class="absolute -right-4 -top-4 w-20 h-20 bg-orange-50 rounded-full blur-2xl group-hover:bg-orange-100 transition-soft"></div>
            </div>
        </div>

        <!-- Table Card -->
        <div class="bg-white rounded-[2.5rem] shadow-sm border border-slate-100 overflow-hidden ring-1 ring-slate-100">
            <div class="p-10 flex flex-col md:flex-row justify-between items-center border-b border-slate-50 gap-4">
                <div>
                    <h2 class="text-2xl font-black text-slate-800">Daftar Spareparts</h2>
                    <p class="text-slate-400 text-sm">Terdapat total <%= stats.totalParts %> jenis barang di sistem.</p>
                </div>
                <a href="/admin/parts/add" class="inline-flex items-center px-8 py-4 bg-indigo-600 hover:bg-indigo-700 text-white font-black rounded-2xl shadow-xl shadow-indigo-100 transform active:scale-95 transition-soft">
                    <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                    Tambah Sparepart
                </a>
            </div>
            
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="bg-slate-50">
                            <th class="px-10 py-6 text-xs font-bold text-slate-500 uppercase tracking-widest">Barang</th>
                            <th class="px-10 py-6 text-xs font-bold text-slate-500 uppercase tracking-widest text-center">Harga Jual</th>
                            <th class="px-10 py-6 text-xs font-bold text-slate-500 uppercase tracking-widest text-center">Stok</th>
                            <th class="px-10 py-6 text-xs font-bold text-slate-500 uppercase tracking-widest text-right">Manajemen</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-50">
                        <% parts.forEach(part => { %>
                        <tr class="hover:bg-indigo-50/30 transition-soft group">
                            <td class="px-10 py-8">
                                <div class="flex items-center">
                                    <div class="w-16 h-16 rounded-2xl bg-slate-100 mr-6 overflow-hidden flex-shrink-0 shadow-sm border-2 border-white">
                                        <% if(part.image) { %>
                                            <img src="<%= part.image %>" alt="<%= part.name %>" class="w-full h-full object-cover">
                                        <% } else { %>
                                            <div class="w-full h-full flex items-center justify-center text-slate-400">
                                                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                                            </div>
                                        <% } %>
                                    </div>
                                    <div>
                                        <div class="text-lg font-bold text-slate-800 tracking-tight"><%= part.name %></div>
                                        <div class="text-xs font-medium text-slate-400 truncate max-w-xs mt-1"><%= part.description %></div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-10 py-8 text-center">
                                <span class="bg-indigo-50 text-indigo-700 px-4 py-2 rounded-xl text-sm font-black tracking-tight">Rp <%= part.price.toLocaleString('id-ID') %></span>
                            </td>
                            <td class="px-10 py-8 text-center">
                                <% if(part.stock < 10) { %>
                                    <span class="inline-block px-4 py-2 bg-red-100 text-red-700 rounded-xl text-xs font-black uppercase tracking-widest ring-4 ring-red-50">
                                        Kritis: <%= part.stock %>
                                    </span>
                                <% } else { %>
                                    <span class="text-sm font-bold text-slate-600"><%= part.stock %> UNIT</span>
                                <% } %>
                            </td>
                            <td class="px-10 py-8 text-right">
                                <div class="flex justify-end gap-3 transition-soft">
                                    <a href="/admin/parts/edit/<%= part.id %>" class="p-3 bg-white border border-slate-100 rounded-xl shadow-sm text-indigo-600 hover:bg-indigo-600 hover:text-white transition-soft">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                                    </a>
                                    <a href="/admin/parts/delete/<%= part.id %>" onclick="return confirm('Waspada! Hapus data ini secara permanen?')" class="p-3 bg-white border border-slate-100 rounded-xl shadow-sm text-red-600 hover:bg-red-600 hover:text-white transition-soft">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                        
                        <% if (parts.length === 0) { %>
                        <tr>
                            <td colspan="4" class="px-10 py-24 text-center">
                                <div class="flex flex-col items-center opacity-40">
                                    <svg class="w-20 h-20 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                                    <p class="text-xl font-bold italic tracking-tight">Inventori Masih Kosong</p>
                                    <p class="text-sm">Klik 'Tambah Sparepart' untuk mengisi data.</p>
                                </div>
                            </td>
                        </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>

<%- include('../layouts/footer') %>
