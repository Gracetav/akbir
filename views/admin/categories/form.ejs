<%- include('../../layouts/header') %>
<%- include('../../layouts/navbar') %>

<div class="flex">
    <%- include('../../layouts/sidebar') %>
    
    <main class="flex-grow lg:pl-64 pt-8 p-8 max-w-screen-2xl mx-auto">
        <!-- Header -->
        <div class="mb-10">
            <a href="/admin/categories" class="inline-flex items-center text-sm font-bold text-indigo-600 mb-6 hover:text-indigo-800 transition-soft">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                Kembali ke Daftar
            </a>
            <h1 class="text-3xl font-black text-slate-800 tracking-tight mb-2"><%= category ? 'Edit' : 'Tambah' %> Kategori</h1>
            <p class="text-slate-500">Silahkan isi detail kategori di bawah ini.</p>
        </div>

        <div class="max-w-3xl">
            <form action="<%= category ? '/admin/categories/edit/' + category.id : '/admin/categories/add' %>" method="POST" class="bg-white p-10 rounded-[2.5rem] shadow-sm border border-slate-100 ring-1 ring-slate-100">
                <div class="space-y-8">
                    <!-- Name Field -->
                    <div class="space-y-3">
                        <label for="name" class="block text-xs font-bold text-slate-400 uppercase tracking-widest">Nama Kategori</label>
                        <input type="text" name="name" id="name" value="<%= category ? category.name : '' %>" required
                               class="w-full px-6 py-4 bg-slate-50 border-2 border-transparent focus:border-indigo-500 focus:bg-white rounded-2xl outline-none transition-soft text-slate-800 font-bold placeholder:text-slate-300"
                               placeholder="Contoh: Mesin, Kelistrikan, Body, dll">
                    </div>

                    <!-- Submit Button -->
                    <div class="pt-4">
                        <button type="submit" class="w-full py-5 bg-indigo-600 hover:bg-indigo-700 text-white font-black rounded-2xl shadow-xl shadow-indigo-100 transform active:scale-[0.98] transition-soft flex items-center justify-center">
                            <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            Simpan Kategori
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </main>
</div>

<%- include('../../layouts/footer') %>
