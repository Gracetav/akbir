<%- include('../layouts/header') %>
<%- include('../layouts/navbar') %>

<div class="flex">
    <%- include('../layouts/sidebar') %>
    
    <main class="flex-grow lg:pl-64 pt-8 p-8 max-w-screen-2xl mx-auto">
        <div class="mb-10">
            <a href="/admin/categories" class="inline-flex items-center text-indigo-600 font-bold mb-4 hover:underline">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                Kembali ke Daftar
            </a>
            <h1 class="text-3xl font-black text-slate-800 tracking-tight">Tambah Kategori Baru</h1>
        </div>

        <div class="max-w-2xl bg-white rounded-[2.5rem] shadow-sm border border-slate-100 overflow-hidden ring-1 ring-slate-100 p-10">
            <form action="/admin/categories/add" method="POST" class="space-y-8">
                <div>
                    <label for="name" class="block text-sm font-bold text-slate-700 uppercase tracking-widest mb-3">Nama Kategori</label>
                    <input type="text" name="name" id="name" required placeholder="Contoh: Mesin, Kelistrikan, Aksesoris..." 
                           class="w-full px-6 py-4 bg-slate-50 border-none rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:bg-white transition-soft text-lg font-medium">
                </div>

                <div class="pt-4 border-t border-slate-50">
                    <button type="submit" class="w-full py-5 bg-indigo-600 hover:bg-indigo-700 text-white font-black rounded-2xl shadow-xl shadow-indigo-100 transform active:scale-95 transition-soft text-lg">
                        Simpan Kategori
                    </button>
                    <p class="mt-4 text-center text-slate-400 text-sm italic">Slug akan digenerate secara otomatis berdasarkan nama.</p>
                </div>
            </form>
        </div>
    </main>
</div>

<%- include('../layouts/footer') %>
